# 线上环境
ENV = 'production'

# 构建期
VITE_PORT=5173
# open 运行时自动打开浏览器
VITE_OPEN=false

# 线上环境接口地址 - 通过Nginx代理访问后端
# 由于Nginx已配置 /api 代理，前端应该访问Nginx而不是直接访问后端端口
VITE_API_BASE_URL = 'http://106.54.166.76'

VITE_PUBLIC_PATH=/

# 网站主标题（菜单导航、浏览器当前网页标题)
VITE_GLOBAL_TITLE=N-Tester
#网站副标题（登录页顶部文字）
VITE_GLOBAL_VICE_TITLE=N-Tester

VITE_APP_NAMESPACE=N-Tester
# 后端接口前缀
VITE_API_PREFIX = '/api'

# 静默Sass弃用警告
SASS_SILENCE_DEPRECATIONS='legacy-js-api,import'
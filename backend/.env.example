# 服务对外基地址（报告链接、截图/视频 URL 组装等）
BASE_URL=http://127.0.0.1:8100

# Redis 配置
# 有认证
# REDIS_URI=redis://root:password@localhost:6379/4
# 无认证
REDIS_URI=redis://:redis@localhost:6379/4

# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=ntester

# 旧方式（兼容已部署用户）
# Windows 用户使用 aiomysql

# 注意：密码含特殊字符时需手动 URL 编码，例如 @ -> %40，: -> %3A
# MYSQL_DATABASE_URI=mysql+aiomysql://root:123456@localhost:3306/ntester?charset=UTF8MB4
# MYSQL_DATABASE_URI_SYNC=mysql+pymysql://root:123456@localhost:3306/ntester?charset=UTF8MB4


# Linux/Mac 用户可以使用 asyncmy

# MYSQL_DATABASE_URI=mysql+asyncmy://root:Rebort@localhost:3306/ntester?charset=UTF8MB4
# MYSQL_DATABASE_URI_SYNC=mysql+pymysql://root:Rebort@localhost:3306/ntester?charset=UTF8MB4

# PostgreSQL数据库配置
# 异步
#MYSQL_DATABASE_URI=postgresql+asyncpg://user:pass@host:5432/dbname
# 同步
#MYSQL_DATABASE_URI_SYNC=postgresql+psycopg2://user:pass@host:5432/dbname

# SQLite数据库配置

# 异步
#MYSQL_DATABASE_URI=sqlite+aiosqlite:///./database.db
# 同步
#MYSQL_DATABASE_URI_SYNC=sqlite:///./database.db

# celery
CELERY_BROKER_URL=redis://:redis@localhost:6379/5
CELERY_RESULT_BACKEND=redis://:redis@localhost:6379/5
# 使用推荐方式（DB_HOST 等）时，CELERY_BEAT_DB_URL 可不填，自动复用上方数据库配置
# CELERY_BEAT_DB_URL=mysql+pymysql://root:123456@localhost:3306/ntester?charset=UTF8MB4

# ================================================= #
# ******** OAuth 配置 *********** #
# ================================================= #

# 是否给 OAuth 登录用户授予管理员权限（生产环境建议关闭）
GRANT_ADMIN_TO_OAUTH_USER=false

# Gitee OAuth
GITEE_CLIENT_ID=your-gitee-client-id
GITEE_CLIENT_SECRET=your-gitee-client-secret
GITEE_REDIRECT_URI=http://localhost:3000/oauth/gitee/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:3000/oauth/github/callback

# QQ 互联 OAuth
QQ_APP_ID=your-qq-app-id
QQ_APP_KEY=your-qq-app-key
QQ_REDIRECT_URI=http://localhost:3000/oauth/qq/callback

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google/callback

# 微信开放平台 OAuth
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret
WECHAT_REDIRECT_URI=http://localhost:3000/oauth/wechat/callback

# Microsoft OAuth
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_REDIRECT_URI=http://localhost:3000/oauth/microsoft/callback

# 钉钉 OAuth
DINGTALK_APP_ID=your-dingtalk-app-id
DINGTALK_APP_SECRET=your-dingtalk-app-secret
DINGTALK_REDIRECT_URI=http://localhost:3000/oauth/dingtalk/callback

# 飞书 OAuth
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_REDIRECT_URI=http://localhost:3000/oauth/feishu/callback



# ================================================= #
# ******** APP 自动化（Airtest / 执行器，与 config.py 一致） *********** #
# ================================================= #

# 项目根（截图目录 media/app_result、相对图片路径）；不填则自动推断为仓库根
# APP_PROJECT_ROOT=E:/Fastapi/vue-fastapi-admin

# 与 project_path 同名，可与 APP_PROJECT_ROOT 二选一
# PROJECT_PATH=

# 截图/视频对外 URL 前缀（浏览器能访问到的后端地址）；不填则用下方 BASE_URL（config 默认 8100）
# APP_PUBLIC_BASE_URL=http://127.0.0.1:8100

# getenv 兼容（可选）
# PUBLIC_BASE_URL=http://127.0.0.1:8100

# type=6 删除差更：adb rm -rf，多个路径用分号分隔
# APP_DEVICE_RM_PATHS=

# 短信验证码步骤：短信正文需包含的关键字
# APP_SMS_BODY_KEYWORD=识别文案

# 1/true/yes 时使用 Appium 执行器（可不装 airtest）
# USE_APPIUM_APP_EXECUTOR=

APPIUM_SERVER_URL=http://127.0.0.1:4723
APP_TEMPLATE_ROOT=backend

